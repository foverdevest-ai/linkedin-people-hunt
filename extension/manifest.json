{
  "manifest_version": 3,
  "name": "LinkedIn People Hunt Connector",
  "version": "0.1.0",
  "description": "Connects linkedin.com session to LinkedIn People Hunt internal app.",
  "permissions": ["storage", "activeTab", "scripting", "clipboardRead", "alarms", "tabs"],
  "host_permissions": [
    "https://www.linkedin.com/*",
    "http://localhost:3000/*",
    "https://people-hunt.personeel.com/*",
    "https://*.personeel.com/*"
  ],
  "background": {
    "service_worker": "src/background.js"
  },
  "content_scripts": [
    {
      "matches": ["https://www.linkedin.com/*"],
      "js": ["src/content.js"],
      "run_at": "document_idle"
    }
  ],
  "action": {
    "default_title": "LinkedIn People Hunt",
    "default_popup": "popup.html"
  }
}
